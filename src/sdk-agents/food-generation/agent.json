{
  "id": "food-generation",
  "version": "2.1.0",
  "type": "agent",
  "description": "Generates food items based on description and criteria",
  "interface": {
    "input": { "$ref": "./schema.ts#FoodGenerationInputSchema" },
    "output": { "$ref": "./schema.ts#FoodGenerationOutputSchema" }
  },
  "mcpServers": {},
  "skills": {
    "path": "skills",
    "expose": []
  },
  "tools": {
    "source": "registry",
    "allowlist": []
  },
  "progress": {
    "aiDriven": true,
    "fallbackSteps": [
      { "name": "Parse food description", "weight": 20 },
      { "name": "Generate nutritional data", "weight": 50 },
      { "name": "Validate and format output", "weight": 30 }
    ]
  },
  "config": {
    "tier": "balanced",
    "temperature": 1,
    "maxSteps": 10,
    "maxTokens": 8192,
    "timeout": 120000,
    "executionMode": "durable",
    "skipSynthesis": true,
    "outputArtifact": "foods",
    "durability": {
      "enabled": true,
      "maxDurationMs": 600000,
      "retry": {
        "maxAttempts": 3,
        "backoffMs": 1000,
        "backoffMultiplier": 2
      },
      "checkpointStrategy": "step"
    }
  }
}
