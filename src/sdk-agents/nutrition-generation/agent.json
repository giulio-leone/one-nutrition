{
  "id": "nutrition-generation",
  "version": "2.1.0",
  "type": "agent",
  "description": "Multi-agent nutrition plan generator using SDK v4.2 with durable execution",
  "interface": {
    "input": { "$ref": "./schema.ts#NutritionGenerationInputSchema" },
    "output": { "$ref": "./schema.ts#NutritionGenerationOutputSchema" }
  },
  "mcpServers": {},
  "skills": {
    "path": "skills",
    "expose": []
  },
  "tools": {
    "source": "registry",
    "allowlist": []
  },
  "progress": {
    "aiDriven": true,
    "fallbackSteps": [
      { "name": "Calculate daily macros", "weight": 5 },
      { "name": "Distribute meal macros", "weight": 5 },
      { "name": "Plan daily structure", "weight": 15 },
      { "name": "Select foods", "weight": 20 },
      { "name": "Generate patterns", "weight": 35 },
      { "name": "Validate plan", "weight": 10 },
      { "name": "Assemble final plan", "weight": 10 }
    ]
  },
  "config": {
    "tier": "balanced",
    "temperature": 1,
    "maxSteps": 50,
    "maxTokens": 8192,
    "timeout": 600000,
    "executionMode": "durable",
    "skipSynthesis": true,
    "outputArtifact": "finalPlan",
    "durability": {
      "enabled": true,
      "maxDurationMs": 1800000,
      "retry": {
        "maxAttempts": 5,
        "backoffMs": 2000,
        "backoffMultiplier": 2
      },
      "checkpointStrategy": "step"
    }
  }
}
