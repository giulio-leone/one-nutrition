{
  "id": "meal-planner",
  "version": "2.1.0",
  "type": "agent",
  "description": "Plans meal structure and timing for the day",
  "interface": {
    "input": { "$ref": "./schema.ts#MealPlannerInputSchema" },
    "output": { "$ref": "./schema.ts#MealPlannerOutputSchema" }
  },
  "mcpServers": {},
  "skills": {
    "path": "skills",
    "expose": []
  },
  "tools": {
    "source": "registry",
    "allowlist": []
  },
  "progress": {
    "aiDriven": true,
    "fallbackSteps": [
      { "name": "Analyze goals and restrictions", "weight": 30 },
      { "name": "Design meal timing", "weight": 40 },
      { "name": "Structure meal composition", "weight": 30 }
    ]
  },
  "config": {
    "tier": "fast",
    "temperature": 1,
    "maxSteps": 10,
    "maxTokens": 4096,
    "timeout": 60000,
    "executionMode": "durable",
    "durability": {
      "enabled": true,
      "maxDurationMs": 300000,
      "retry": {
        "maxAttempts": 2,
        "backoffMs": 500,
        "backoffMultiplier": 2
      },
      "checkpointStrategy": "step"
    }
  }
}
